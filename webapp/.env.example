# Candle webapp environment

# Base URL of the Candle BFF (Backend-for-Frontend).
# Inlined into the static bundle at build time, so it MUST be prefixed NEXT_PUBLIC_.
# Web browser local dev:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Android emulator local dev:
#   NEXT_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Gateway URL for auth endpoints (OAuth, token lifecycle, /me).
# When set, auth/* calls go directly to the Spring Cloud Gateway instead of the BFF.
# Leave unset in local dev to fall back to the BFF mock.
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:8000

# ── 시세 실시간 WS (BFF /ws) ────────────────────────────────────────
# 시세 WS는 게이트웨이(8000)를 타지 않는다 — 게이트웨이는 WS 업그레이드 프록시/인증이 안 된다.
# BFF(/ws)에 직결한다. 미설정 시 API base(=게이트웨이)로 폴백해 401이 나므로 반드시 설정.
# dev: BFF 직결. prod: 게이트웨이/ALB가 /ws passthrough 하는 wss:// 도메인.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080

# ── 종목 실시간 채팅 (chatting-service) ─────────────────────────────
# 채팅은 BFF가 아니라 chatting-service(WS 게이트웨이)에 붙는다.
# 정적 export라 빌드타임에 인라인되므로 환경마다 그 환경 값으로 빌드해야 한다.
# dev: chatting-service 직결. prod: 게이트웨이/ALB 도메인(미설정 시 API base로 폴백).
#   - REST 방배정(/chat/rooms)
# NEXT_PUBLIC_CHAT_API_BASE_URL=http://localhost:8090
#   - WS(/chat/ws). prod은 반드시 wss:// (ALB가 /chat/ws passthrough)
# NEXT_PUBLIC_CHAT_WS_BASE_URL=ws://localhost:8090

# ── OAuth (AUTH-015) ───────────────────────────────────────────────
# Only PUBLIC values belong on the client (client IDs + redirect URI).
# OAuth client *secrets* and the JWT signing secret are NEVER here — they live
# in the Auth Service's server-side config.
# NEXT_PUBLIC_OAUTH_GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_OAUTH_KAKAO_CLIENT_ID=
# NEXT_PUBLIC_OAUTH_NAVER_CLIENT_ID=
# NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
#
# 네이티브(Capacitor) OAuth 딥링크 콜백. 웹과 달라야 함(WebView origin·구글 WebView 차단 때문).
# provider 콘솔 + auth-service redirect_uri allowlist에 동일 값 등록 필요. 기본: appId 커스텀 스킴.
# NEXT_PUBLIC_OAUTH_NATIVE_REDIRECT_URI=com.candle.app://auth/callback
