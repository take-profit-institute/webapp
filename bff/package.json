{
  "name": "@candle/bff",
  "version": "0.1.0",
  "private": true,
  "description": "Backend-for-Frontend for the Candle mock-investment app",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "predev": "tsc -p ../shared/tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "prebuild": "tsc -p ../shared/tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "pretypecheck": "tsc -p ../shared/tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "grpc:gen": "buf generate ${PROTO_DIR:-../../../../IdeaProjects/candle/proto} --template buf.gen.yaml"
  },
  "dependencies": {
    "@candle/shared": "*",
    "@fastify/cors": "^11.0.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@fastify/websocket": "^11.2.0",
    "@grpc/grpc-js": "^1.14.4",
    "@sinclair/typebox": "^0.34.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.11.1",
    "nice-grpc": "^2.1.16"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.0.0",
    "ts-proto": "^2.11.8",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
