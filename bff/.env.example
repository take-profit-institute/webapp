# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated exact origins and wildcard origins for browser clients.
CORS_ORIGINS=capacitor://localhost,https://localhost,http://localhost,http://localhost:3000,http://localhost:3001,https://*.vercel.app,https://*.builderio.dev

# Data source: "mock" (default, no backend needed) or "grpc" (real microservices).
# Set to "grpc" when running auth-service + user-service locally.
DATA_SOURCE=mock

# Auth Service REST URL (used when DATA_SOURCE=grpc).
AUTH_SERVICE_URL=http://localhost:8081

# --- Korea Investment ---
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=



